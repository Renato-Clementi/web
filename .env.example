# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must never be committed.
#
# Next.js loads env files automatically (.env, .env.local, .env.<mode>).
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Everything else stays server-only — keep secrets unprefixed.

# Public site URL used for absolute links / metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secrets go here (no NEXT_PUBLIC_ prefix), e.g.:
# API_KEY=

# --- Auth (Clerk) ----------------------------------------------------------
# Provider for sign-up / login / sessions. See docs/adr/0001-auth-provider.md
# for why Clerk. Create a (free) application at https://dashboard.clerk.com,
# then copy its API keys from the "API keys" page. The publishable key is safe
# to ship to the browser (NEXT_PUBLIC_); the secret key is server-only.
# Without these the app builds and unit-tests pass, but live sign-in/up needs
# real keys (use pk_test_/sk_test_ for dev, pk_live_/sk_live_ in production).
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# CLERK_SECRET_KEY=sk_test_xxx
# Where Clerk's hosted widgets live and where to land users (defaults shown):
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# --- Database (Postgres + pgvector) ----------------------------------------
# Connection string used by the app and the migration runner. The role must be
# an ordinary role (NOT superuser / NOT BYPASSRLS) so Row-Level Security tenant
# isolation is enforced. See db/README.md.
#   npm run db:migrate   # apply db/migrations/*.sql
#   npm run db:smoke     # acceptance smoke test (needs a live DB)
# DATABASE_URL=postgres://user:password@host:5432/baboo
#
# Local dev with Docker:
#   docker run -d --name baboo-pg -e POSTGRES_PASSWORD=postgres \
#     -p 5432:5432 pgvector/pgvector:pg16
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# --- Leads dashboard (/dashboard/leads) ------------------------------------
# When these are set, the dashboard reads the real Odoo `crm.lead` source over
# JSON-RPC. When unset, it falls back to clearly-labelled demo data so the page
# still renders locally. These mirror the mcp-odoo connector's variables.
# ODOO_URL=https://your-odoo-host
# ODOO_DB=your-database
# ODOO_USERNAME=you@example.com
# ODOO_API_KEY=
# Optional: request timeout (ms) and max records fetched.
# ODOO_TIMEOUT_MS=30000
# ODOO_MAX_LIMIT=5000
