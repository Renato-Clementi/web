# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must never be committed.
#
# Next.js loads env files automatically (.env, .env.local, .env.<mode>).
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Everything else stays server-only — keep secrets unprefixed.

# Public site URL used for absolute links / metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only secrets go here (no NEXT_PUBLIC_ prefix), e.g.:
# DATABASE_URL=
# API_KEY=
