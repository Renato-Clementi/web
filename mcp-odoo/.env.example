# Copy to `.env` (git-ignored) or set these in your MCP client config.
# No secret is ever hard-coded — the server reads everything from the environment.

# Base URL of the Odoo 18 instance (no trailing slash needed).
ODOO_URL=https://my-company.odoo.com
# Database name.
ODOO_DB=my-company
# Login (email/username) of the Odoo user the agent acts as.
ODOO_USERNAME=admin
# API key generated in Odoo: Preferences > Account Security > New API Key.
ODOO_API_KEY=

# --- Optional ---
# Request timeout in milliseconds (default 30000).
# ODOO_TIMEOUT_MS=30000
# Hard cap on records returned per query (default 1000).
# ODOO_MAX_LIMIT=1000
# Set to true/1 to disable create/write/unlink tools (read-only agents).
# ODOO_MCP_READONLY=false
